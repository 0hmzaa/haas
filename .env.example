NODE_ENV=development

# Database
POSTGRES_DB=haas
POSTGRES_USER=haas
POSTGRES_PASSWORD=haas
DATABASE_URL=postgresql://haas:haas@localhost:5432/haas?schema=public

# API
PORT=4000
PROOF_STORAGE_ROOT=/storage/proofs

# x402
X402_REQUIRE_SIGNED_WEBHOOK=true
X402_FACILITATOR_ID=facilitator-demo
X402_FACILITATOR_SIGNING_SECRET=dev-facilitator-secret
X402_SIGNATURE_MAX_AGE_SECONDS=300

# World ID
WORLD_ID_MODE=mock
WORLD_ID_VERIFY_URL=
WORLD_ID_APP_ID=
WORLD_ID_API_KEY=
WORLD_ID_TIMEOUT_MS=8000

# Hedera
HEDERA_ENABLED=false
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ACCOUNT_ID=
HEDERA_OPERATOR_PRIVATE_KEY=
HEDERA_HCS_TOPIC_ID=
HEDERA_SCHEDULE_ADMIN_KEY=replace-with-testnet-schedule-admin-key
HEDERA_ESCROW_ACCOUNT_ID=
HEDERA_MIRROR_NODE_BASE_URL=

# Web
WEB_PORT=3000
API_BASE_URL=http://localhost:4000
