NODE_ENV=development

# Database
POSTGRES_DB=haas
POSTGRES_USER=haas
POSTGRES_PASSWORD=haas
DATABASE_URL=postgresql://haas:haas@localhost:5432/haas?schema=public

# API
PORT=4000
PROOF_STORAGE_ROOT=/storage/proofs

# Hedera
HEDERA_ENABLED=false
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ACCOUNT_ID=
HEDERA_OPERATOR_PRIVATE_KEY=
HEDERA_HCS_TOPIC_ID=
HEDERA_SCHEDULE_ADMIN_KEY=replace-with-testnet-schedule-admin-key
HEDERA_ESCROW_ACCOUNT_ID=
HEDERA_MIRROR_NODE_BASE_URL=

# Web
WEB_PORT=3000
API_BASE_URL=http://localhost:4000
