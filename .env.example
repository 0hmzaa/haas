NODE_ENV=development

# Database
POSTGRES_DB=haas
POSTGRES_USER=haas
POSTGRES_PASSWORD=haas
DATABASE_URL=postgresql://haas:haas@localhost:5432/haas?schema=public

# API
PORT=4000
PROOF_STORAGE_ROOT=./storage/proofs
TASK_POLICY_MODE=enforce
AUTO_RECONCILIATION_ENABLED=true
AUTO_RECONCILIATION_INTERVAL_MS=30000
AUTO_RECONCILIATION_BATCH_SIZE=25
AUTO_RECONCILIATION_RUN_ON_START=true

# x402
X402_REQUIRE_SIGNED_WEBHOOK=true
X402_FACILITATOR_ID=facilitator-demo
X402_FACILITATOR_SIGNING_SECRET=dev-facilitator-secret
X402_SIGNATURE_MAX_AGE_SECONDS=300
X402_VERIFY_HEDERA_TX=false
X402_MIRROR_NODE_BASE_URL=
X402_FACILITATOR_MODE=verify-settle
X402_FACILITATOR_API_BASE_URL=https://api.testnet.blocky402.com
X402_FACILITATOR_VERIFY_PATH=/verify
X402_FACILITATOR_SETTLE_PATH=/settle
X402_FACILITATOR_FUNDING_PATH=/v1/facilitator/payments/hedera/fund
X402_FACILITATOR_API_KEY=
X402_FACILITATOR_API_KEY_HEADER=X-Api-Key
X402_FACILITATOR_TIMEOUT_MS=10000
X402_PAYMENT_NETWORK=hedera-testnet
X402_PAYMENT_FEE_PAYER=
X402_PAYMENT_RESOURCE_BASE_URL=http://localhost:4000
X402_PAYMENT_DESCRIPTION=HumanAsAService order funding
X402_PAYMENT_MIME_TYPE=application/json
X402_PAYMENT_MAX_TIMEOUT_SECONDS=300
REAL_HEDERA_TX_ID=
REAL_PAYER_ACCOUNT=
REAL_PAYER_PRIVATE_KEY=
REAL_ALLOW_WEBHOOK_FALLBACK=false
REAL_ORDER_AMOUNT=1.00
REAL_ORDER_CURRENCY=HBAR
REAL_CLIENT_ID=client-live

# World ID
WORLD_ID_MODE=mock
WORLD_ID_VERIFY_URL=
WORLD_ID_APP_ID=
WORLD_ID_API_KEY=
WORLD_ID_TIMEOUT_MS=8000
WORLD_VERIFY_PAYLOAD_FILE=

# Hedera
HEDERA_ENABLED=false
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ACCOUNT_ID=
HEDERA_OPERATOR_PRIVATE_KEY=
HEDERA_OPERATOR_PRIVATE_KEY_TYPE=auto
HEDERA_HCS_TOPIC_ID=
HEDERA_SCHEDULE_ADMIN_KEY=replace-with-testnet-schedule-admin-key
HEDERA_SCHEDULE_ADMIN_KEY_TYPE=auto
HEDERA_ESCROW_ACCOUNT_ID=
HEDERA_MIRROR_NODE_BASE_URL=

# Web
WEB_PORT=3000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
